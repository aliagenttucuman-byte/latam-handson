SELECT
  CAST(NULL AS STRING) AS event_name,
  CAST(NULL AS DATE)   AS event_date
FROM `ebiz-data-prod.ebiz_google_analytics_4.events_*`  -- ejemplo
WHERE FALSE

UNION ALL

